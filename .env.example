## Node environment. Affects logging, error formatting, dev-only routes.
## Validator default: development.
NODE_ENV=development

## Structured-logger threshold (lib/server/log.ts): debug|info|warn|error.
## Optional, read directly via process.env (not in the zod validator).
## Default: production -> info, otherwise -> debug.
# LOG_LEVEL=debug

## Supabase - server-side keys; never expose service-role key to client browsers
# For local development, point at the local Supabase stack started via `supabase start`
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_ANON_KEY=

## Legacy fallback names accepted by lib/server/db/supabase.ts. Validator
## requires EITHER SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL (same for anon key).
## Older Vercel deployments still ship these; new setups should use the
## non-prefixed names above.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key - required for mutating routes (CSV import, analysis batch,
# enrichment batch). Bypasses RLS. NEVER ship to the browser. Get it from
# `supabase status` (local) or Supabase Studio -> Settings -> API.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (used by Drizzle in lib/server/db, plus
# scripts/session-pipeline.mjs and scripts/webdb-import.mjs)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres

## OpenRouter - server-side only. Optional: lib/server/llm.ts also accepts a
## per-request `x-openrouter-key` header, so BYOK works without a server key.
OPENROUTER_API_KEY=

## Default LLM model used when no per-request override is supplied.
## Validator default: anthropic/claude-sonnet-4.
LLM_DEFAULT_MODEL=anthropic/claude-sonnet-4

## Auth gate (G1). REQUIRED by lib/server/env.ts validator since 2026-05-15
## (was optional; tightened after CSRF + rate-limit hardening). Setting
## either empty makes the boot exit with status 1, so the previous
## "pass-through (dev) mode" is no longer reachable.
## GATE_TOKEN = sha256 of GATE_PASSWORD. Generate with:
##   echo -n "yourpassword" | sha256sum
GATE_PASSWORD=
GATE_TOKEN=

## WEBDB MySQL — consumed by scripts/webdb-import.mjs AND by the runtime
## route POST /api/events/sync (see app/api/events/sync/route.ts). The
## sync endpoint refuses cleanly when HOST is unset; when HOST is set,
## USER + DATABASE are required (lib/server/env.ts conditional check).
## Local dev default port for the oeaw-webdb-mysql docker container is 54499.
## For production: see docs/TYPO3_MYSQL_PERMISSIONS.md for a read-only
## GRANT-statement template covering every table the app reads.
WEBDB_MYSQL_HOST=
WEBDB_MYSQL_PORT=54499
WEBDB_MYSQL_USER=
WEBDB_MYSQL_PASSWORD=
WEBDB_MYSQL_DATABASE=

## Events location-extraction LLM fallback (Phase 2). When 'true', the
## events sync sends rows whose location the cheerio parser can't extract
## to OpenRouter (default model: deepseek/deepseek-chat, ~$0.27/MTok in).
## Requires OPENROUTER_API_KEY. Cost: ~0.7 cents per full sync at the
## current ~27-row miss-rate. Off by default.
EVENTS_LLM_FALLBACK_ENABLED=false
# EVENTS_LLM_FALLBACK_MODEL=deepseek/deepseek-chat

## MeisterTask one-way push (lib/meistertask/*)
## PAT erstellen auf https://www.mindmeister.com/api -> "Persoenliche Zugriffstoken"
## Required scopes: meistertask, userinfo.email, userinfo.profile
## In MeisterTask UI:
##   PROJECT_ID = number visible in URL when project is open (script-only,
##                used by scripts/test-meistertask-push.mjs; not validated)
##   DEFAULT_SECTION_ID = where new tasks land (z.B. "Inbox")
## Discovery: GET /api/projects + /api/projects/{id}/sections
MEISTERTASK_API_TOKEN=
MEISTERTASK_PROJECT_ID=
MEISTERTASK_DEFAULT_SECTION_ID=

## Optional: Score-Band-Labels (beide setzen oder beide weglassen).
## Wenn beide gesetzt: Tasks bekommen ein Label (Hoch >=85%, Mittel sonst).
MEISTERTASK_HIGH_LABEL_ID=
MEISTERTASK_MID_LABEL_ID=

## Optional: allow-list of origins permitted as the appBaseUrl in MeisterTask
## task notes (comma-separated). Defaults cover the two Vercel projects +
## localhost. Override for preview deploys or a custom domain.
ALLOWED_ORIGINS=
