## Supabase — server-side keys; never expose service-role key to client browsers
# For local development, point at the local Supabase stack started via `supabase start`
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_ANON_KEY=

# Service-role key — required for mutating routes (CSV import, analysis batch,
# enrichment batch). Bypasses RLS. NEVER ship to the browser. Get it from
# `supabase status` (local) or Supabase Studio → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (used by scripts/session-pipeline.mjs and scripts/webdb-import.mjs)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres

## OpenRouter — server-side only
OPENROUTER_API_KEY=

## Auth gate (G1). Both must be set for the middleware to enforce auth;
## leaving GATE_TOKEN empty puts middleware in pass-through (dev) mode.
## GATE_TOKEN = sha256 of GATE_PASSWORD. Generate with:
##   echo -n "yourpassword" | sha256sum
GATE_PASSWORD=
GATE_TOKEN=

## Optional: WebDB MySQL connection (for the import script)
WEBDB_MYSQL_HOST=
WEBDB_MYSQL_PORT=3306
WEBDB_MYSQL_USER=
WEBDB_MYSQL_PASSWORD=
WEBDB_MYSQL_DATABASE=

## MeisterTask one-way push (lib/meistertask/*)
## PAT erstellen auf https://www.mindmeister.com/api → "Persönliche Zugriffstoken"
## Required scopes: meistertask, userinfo.email, userinfo.profile
## In MeisterTask UI:
##   PROJECT_ID = number visible in URL when project is open
##   DEFAULT_SECTION_ID = where new tasks land (z.B. "Inbox")
## Discovery: GET /api/projects + /api/projects/{id}/sections
MEISTERTASK_API_TOKEN=
MEISTERTASK_PROJECT_ID=
MEISTERTASK_DEFAULT_SECTION_ID=

## Optional: Score-Band-Labels (beide setzen oder beide weglassen).
## Wenn beide gesetzt: Tasks bekommen ein Label (Hoch ≥85%, Mittel sonst).
MEISTERTASK_HIGH_LABEL_ID=
MEISTERTASK_MID_LABEL_ID=
